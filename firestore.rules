rules_version = '2';

// =====================================================================
// 認証ベースのセキュリティルール（Phase1 認証基盤）
//
// - 投稿の読み書きは「承認済み(approved)」ユーザーのみ
// - users ドキュメントは本人のみ作成・更新可。ただし approved / role は
//   本人が変更できない（承認は Cloud Functions / 管理者のみ）
// - registrationApprovals / mail はクライアントから一切アクセス不可
//   （Cloud Functions / Trigger Email 拡張が Admin SDK 経由で操作する）
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function isApproved() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).approved == true;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).role == 'admin';
    }

    // ユーザー
    match /users/{userId} {
      allow read: if isSignedIn();

      // 新規登録: 本人のみ。未承認・一般ロールでの作成を強制する
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.approved == false
        && request.resource.data.role == 'member';

      // 本人による更新: approved / role は変更不可
      allow update: if (isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.approved == resource.data.approved
          && request.resource.data.role == resource.data.role)
        || isAdmin();

      allow delete: if isAdmin();
    }

    // 投稿
    match /posts/{postId} {
      allow read: if isApproved();
      allow create: if isApproved()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isApproved()
        && (resource.data.userId == request.auth.uid || isAdmin());

      // コメント
      match /comments/{commentId} {
        allow read: if isApproved();
        allow create: if isApproved()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isApproved()
          && (resource.data.userId == request.auth.uid || isAdmin());
      }

      // リアクション（1ユーザー1ドキュメント）
      match /reactions/{reactionUserId} {
        allow read: if isApproved();
        allow write: if isApproved() && request.auth.uid == reactionUserId;
      }
    }

    // 承認トークン: クライアントからは一切アクセス不可（Functions のみ）
    match /registrationApprovals/{userId} {
      allow read, write: if false;
    }

    // 送信メールキュー: クライアントからは一切アクセス不可（拡張/Functions のみ）
    match /mail/{mailId} {
      allow read, write: if false;
    }
  }
}
