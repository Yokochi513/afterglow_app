rules_version = '2';

// =====================================================================
// 【暫定・開発用ルール】
// 現状アプリは認証(Firebase Auth)が未実装のため、認証なしで読み書きを
// 許可しています。テストモードのような期限切れはありません。
//
// ⚠️ セキュリティ警告: このルールは誰でもデータの閲覧・改ざん・削除が
// 可能な状態です。本番公開前に必ず認証ベースのルールへ差し替えること。
//
// Phase1 の認証基盤(メールドメイン制限 + Firestore ユーザー検証)実装後、
// 例: allow read: if request.auth != null;
//     allow write: if request.auth != null && request.auth.uid == ...;
// のように制限すること。docs/prompts/phase1_roadmap.md 参照。
// =====================================================================
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
